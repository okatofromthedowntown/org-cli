{
  "categories": {
    "mode": "override",
    "value": [
      "Music",
      "Images",
      "Documents",
      "Installers",
      "Archives",
      "Videos",
      "Keys"
    ]
  },
  "rules": {
    "mode": "override",
    "value": [
      {
        "match": [".mp3", ".m4a"],
        "target": "Music",
        "priority": 0
      },
      {
        "match": [".jpg", ".jpeg", ".png", ".heic", ".webp"],
        "target": "Images",
        "priority": 0
      },
      {
        "match": [".pdf", ".epub", ".txt", ".md"],
        "target": "Documents",
        "priority": 0
      },
      {
        "match": [".dmg", ".exe", ".iso", ".app"],
        "target": "Installers",
        "priority": 0
      },
      {
        "match": [".zip"],
        "target": "Archives",
        "priority": 0
      },
      {
        "match": [".mp4"],
        "target": "Videos",
        "priority": 0
      },
      {
        "match": [".key", ".cer"],
        "target": "Keys",
        "priority": 0
      }
    ]
  },
  "fallback": {
    "mode": "override",
    "value": {
      "action": "skip",
      "log": true
    }
  }
}
